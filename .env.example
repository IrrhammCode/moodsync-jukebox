# --- MoodSync Jukebox: AURA PRIME CONFIG ---

# 1. AURA Intelligence (Google Gemini & Groq)
# Get Gemini at: https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here
# Get Groq at: https://console.groq.com/ (Recommended for speed & stability)
GROQ_API_KEY=your_groq_api_key_here

# 2. AURA Voice & Music Generation (ElevenLabs)
# Get one at: https://elevenlabs.io/
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# 3. AURA Cloud Vault (Supabase Online Library)
# URL: Settings -> API -> Project URL
SUPABASE_URL=https://your-project-id.supabase.co
# KEY: Settings -> API -> service_role key (SECRET!)
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# 4. Server Configuration
PORT=3005
FRONTEND_URL=http://localhost:3000
# Production URLs
PRODUCTION_FRONTEND_URL=https://your-app.vercel.app
PRODUCTION_BACKEND_URL=https://your-backend.up.railway.app

# 5. Frontend Configuration (Socket.io)
# Must match the server's URL
NEXT_PUBLIC_SOCKET_URL=http://localhost:3005

# 6. Vector Storage (Optional/Future)
# Get one at: https://turbopuffer.com/
TURBOPUFFER_API_KEY=your_turbopuffer_api_key_here
